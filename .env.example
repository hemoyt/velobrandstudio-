# Supabase (Postgres + Auth + Storage). Create a free project at
# https://supabase.com or self-host: https://supabase.com/docs/guides/self-hosting
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used to encrypt team-provided OpenAI/Gemini keys at rest (AES-256-GCM).
# Generate one with: openssl rand -base64 32
# Rotating this makes previously-saved provider keys undecryptable — treat it
# like any other production secret.
ENCRYPTION_KEY=

# Optional: send team invite emails via Resend (https://resend.com). If unset,
# invite links are still generated and shown in the UI for manual sharing.
RESEND_API_KEY=
INVITE_FROM_EMAIL="VeloBrand Studio <onboarding@resend.dev>"

# NOTE: There is no OPENAI_API_KEY or GEMINI_API_KEY here on purpose. This app
# is bring-your-own-key per team — teams add their own provider keys from
# Team Settings, encrypted with ENCRYPTION_KEY above and never sent to the
# browser. See README for details.
