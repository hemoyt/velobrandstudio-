# VeloBrand Studio needs NO environment variables to run — API keys and the
# designs folder are configured in the app itself (Settings page) and stored
# locally under ~/.velobrand.
#
# The overrides below exist for Docker/server setups only.

# Where settings + project records are stored. Default: ~/.velobrand
#VELOBRAND_HOME=

# Default designs folder (the in-app Settings value wins once set).
# Default: ~/VeloBrand
#VELOBRAND_OUTPUT_DIR=
